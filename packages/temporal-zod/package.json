{
  "name": "temporal-zod",
  "version": "0.6.3",
  "description": "Zod validators for Temporal types.",
  "keywords": [
    "temporal",
    "zod"
  ],
  "homepage": "https://github.com/macalinao/temporal-utils",
  "bugs": {
    "url": "https://github.com/macalinao/temporal-utils/issues"
  },
  "license": "Apache-2.0",
  "author": "Ian Macalinao <me@ianm.com>",
  "repository": "github:macalinao/temporal-utils",
  "files": [
    "dist/",
    "src/",
    "README.md"
  ],
  "type": "module",
  "sideEffects": [
    "./dist/json-schemas.js",
    "./dist/index.js"
  ],
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./base": {
      "types": "./dist/base/index.d.ts",
      "import": "./dist/base/index.js"
    }
  },
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org/"
  },
  "scripts": {
    "build": "tsc",
    "clean": "tsc --build --clean && rm -fr dist/",
    "test": "bun test src/"
  },
  "dependencies": {
    "tslib": "^2.8.1"
  },
  "devDependencies": {
    "@macalinao/tsconfig": "^3.2.5",
    "@types/bun": "latest",
    "ajv": "^8.18.0",
    "ajv-formats": "^3.0.1",
    "temporal-polyfill": "^0.3.0",
    "typescript": "^5.9.2",
    "zod": "^4.1.11"
  },
  "peerDependencies": {
    "temporal-polyfill": "^0.3.0",
    "zod": "^4.0.0"
  }
}
