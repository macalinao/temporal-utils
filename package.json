{
  "name": "monorepo",
  "version": "0.0.1",
  "private": true,
  "description": "Monorepo for TC39 Temporal utilities.",
  "keywords": [],
  "license": "Apache-2.0",
  "author": "Ian Macalinao <me@ianm.com>",
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "build": "turbo run build",
    "clean": "turbo run clean",
    "lint": "oxlint --disable-nested-config && oxfmt --check",
    "lint:fix": "oxlint --disable-nested-config --fix && oxfmt",
    "format": "oxfmt",
    "watch": "turbo watch build",
    "test": "bun test src/",
    "test:cov": "bun test src/ --coverage",
    "typedoc": "typedoc",
    "ci:version": "changeset version && bun update",
    "ci:publish": "./scripts/ci-publish.sh"
  },
  "devDependencies": {
    "@changesets/cli": "^2.31.0",
    "oxfmt": "0.55.0",
    "oxlint": "1.69.0",
    "oxlint-tsgolint": "0.23.0",
    "turbo": "^2.10.0",
    "typedoc": "^0.28.19",
    "typescript": "^5.9.3"
  },
  "engines": {
    "bun": ">=1.0.0",
    "node": ">=22"
  },
  "packageManager": "bun@1.3.1"
}
